# ============================================================
# Wedding Invitation App — Environment Variables
# Copy to .env and fill in your values before deploying.
# ============================================================

# Node environment: production | development
NODE_ENV=production

# Port the Node.js server listens on (nginx proxies to this)
PORT=3000

# Full public URL of your app — used for absolute invite links,
# Telegram share, Open Graph tags. No trailing slash.
APP_BASE_URL=https://wedding.yourdomain.com

# PostgreSQL connection string
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://wedding_user:strongpassword@localhost:5432/wedding_db

# Admin panel password
ADMIN_PASSWORD=change_me_to_something_strong

# Allowed CORS origin — set to APP_BASE_URL in production
# Leave empty to allow all origins (not recommended for production)
CORS_ORIGIN=https://wedding.yourdomain.com

# Optional: email for Certbot SSL certificate notifications
SSL_EMAIL=your@email.com
