# ============================================================
# Свадебные приглашения — переменные окружения
# Скопируйте файл: cp .env.example .env
# Заполните все значения перед запуском
# ============================================================

# Режим запуска: production | development
NODE_ENV=production

# Порт Node.js сервера (nginx проксирует сюда)
PORT=3000

# Ваш домен — отображается в ссылках на приглашения, Telegram-шаринге
# Без слеша в конце!
APP_BASE_URL=https://wedding.yourdomain.com
DOMAIN=wedding.yourdomain.com

# Пароль администраторской панели (/admin)
ADMIN_PASSWORD=смените_на_надёжный_пароль

# PostgreSQL подключение
# Для Docker: меняйте только DB_PASSWORD
DB_PASSWORD=надёжный_пароль_бд

# Если запускаете НЕ через docker-compose (VPS без Docker):
DATABASE_URL=postgresql://wedding_user:надёжный_пароль_бд@localhost:5432/wedding_db

# Email для SSL-сертификата Let's Encrypt (Certbot)
SSL_EMAIL=your@email.com

# Разрешённый CORS-источник — для защиты API в production
CORS_ORIGIN=https://wedding.yourdomain.com
